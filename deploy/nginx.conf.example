server {
    listen 443 ssl http2;
    server_name analytics-bot.example.com;

    # Укажите сертификат Let's Encrypt для своего домена.
    ssl_certificate /etc/letsencrypt/live/analytics-bot.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/analytics-bot.example.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
